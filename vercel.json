{
  "buildCommand": "npm run vercel-build",
  "crons": [
    {
      "path": "/api/cron/search-alerts?frequency=daily",
      "schedule": "0 1 * * *"
    },
    {
      "path": "/api/cron/search-alerts?frequency=weekly",
      "schedule": "0 2 * * 1"
    },
    {
      "path": "/api/cron/sponsor-reminders",
      "schedule": "0 3 * * *"
    }
  ]
}
