generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  phone         String?   @unique
  phoneVerified Boolean   @default(false)
  email         String?   @unique
  emailVerified Boolean   @default(false)
  fullName      String
  passwordHash  String
  role          String    @default("user")
  listingLimitOverride Int?
  isThai        Boolean   @default(true)
  lineVerified  Boolean   @default(false)
  lineUserId    String?   @unique
  googleId      String?   @unique
  facebookId    String?   @unique
  idCardHash    String?   @unique
  idVerified    Boolean   @default(false)
  idSubmittedAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  properties    UserProperty[]
  subscriptions UserSubscription[]
  assignedLeads Lead[]             @relation("AgentLeads")
  agentReviews  AgentReview[]
}

model SiteSettings {
  id                String   @id @default("default")
  homeTitle         String
  homeDescription   String
  homeTitleEn       String   @default("")
  homeDescriptionEn String   @default("")
  keywords          String   @default("")
  titleSuffix       String   @default("| Condominium.in.th")
  adSlotHomeLeaderboard String @default("")
  adSlotHomeMid         String @default("")
  adSlotListingTop      String @default("")
  adSlotListingInfeed   String @default("")
  adSlotPropertyTop     String @default("")
  adSlotPropertySidebar String @default("")
  adSlotBlogTop         String @default("")
  adSlotBlogInarticle   String @default("")
  adSlotFooter          String @default("")
  updatedAt         DateTime @updatedAt
}

model TeamAgent {
  id            String   @id @default(cuid())
  name          String
  role          String
  roleEn        String   @default("")
  agentCategory String   @default("team")
  areas         String   @default("[]")
  languages String   @default("[]")
  deals     Int      @default(0)
  imageUrl  String   @default("")
  sortOrder Int      @default(0)
  published Boolean  @default(true)
  userId        String?  @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  reviews       AgentReview[]

  @@index([published, sortOrder])
  @@index([agentCategory, published, sortOrder])
}

model BlogArticle {
  id               String   @id @default(cuid())
  slug             String   @unique
  title            String
  titleEn          String   @default("")
  excerpt          String
  excerptEn        String   @default("")
  content          String
  contentEn        String   @default("")
  category         String
  categoryEn       String   @default("")
  imageUrl         String   @default("")
  publishedAt      DateTime
  readTime         Int      @default(5)
  seoTitle         String
  seoTitleEn       String   @default("")
  seoDescription   String
  seoDescriptionEn String   @default("")
  status           String   @default("published")
  articleType      String   @default("guide")
  projectId        String?
  project          Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  authorName       String   @default("")
  authorTitle      String   @default("")
  reviewNumber     Int?
  factsJson        String   @default("{}")
  sectionsJson     String   @default("[]")
  galleryUrls      String   @default("[]")
  videoUrl         String   @default("")
  relatedSlugs     String   @default("[]")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([status, publishedAt])
  @@index([articleType, status, publishedAt])
  @@index([projectId])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
}

model PhoneOtp {
  id        String   @id @default(cuid())
  phone     String
  code      String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([phone])
}

model EmailOtp {
  id        String   @id @default(cuid())
  email     String
  code      String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([email])
}

model UserProperty {
  id             String    @id @default(cuid())
  userId         String
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  slug           String    @unique
  title          String
  description    String
  titleEn        String    @default("")
  descriptionEn  String    @default("")
  titleZh        String    @default("")
  descriptionZh  String    @default("")
  titleJa        String    @default("")
  descriptionJa  String    @default("")
  titleAr        String    @default("")
  descriptionAr  String    @default("")
  highlights     String    @default("")
  listingType    String
  propertyType   String    @default("condo")
  price          Int
  priceUnit      String
  bedrooms       Int
  bathrooms      Int
  areaSqm        Float
  landSqWah      Float?
  floor          Int?
  district       String
  btsStation     String?
  address        String
  latitude       Float?
  longitude      Float?
  npaBank        String?
  npaReferenceUrl String?
  features       String    @default("[]")
  images         String    @default("[]")
  status         String    @default("published")
  needsReview    Boolean   @default(false)
  moderationFlags String   @default("[]")
  isSponsored    Boolean   @default(false)
  sponsoredUntil DateTime?
  sponsorReminder3dAt DateTime?
  sponsorReminder1dAt DateTime?
  agentManaged   Boolean   @default(false)
  projectId      String?
  project        Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)
  priceHistory   PriceHistory[]
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([userId])
  @@index([status])
  @@index([needsReview, status])
  @@index([projectId])
}

model Project {
  id             String    @id @default(cuid())
  slug           String    @unique
  name           String
  nameEn         String    @default("")
  developer      String
  location       String
  district       String    @default("")
  btsStation     String?
  amenities      String    @default("[]")
  totalUnits     Int?
  completionDate DateTime?
  imageUrl       String    @default("")
  description    String    @default("")
  descriptionEn  String    @default("")
  published      Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  properties     UserProperty[]
  blogArticles     BlogArticle[]

  @@index([published])
  @@index([district])
}

model Lead {
  id            String   @id @default(cuid())
  name          String
  phone         String?
  email         String?
  message       String
  source        String   @default("contact")
  agentType     String?
  contactMode   String   @default("agent_team") // agent_team | owner_direct
  propertySlug  String?
  propertyTitle String?
  btsStation    String?
  ownerUserId   String?
  posterRole    String?
  status        String   @default("new")
  assignedToId  String?
  assignedTo    User?    @relation("AgentLeads", fields: [assignedToId], references: [id], onDelete: SetNull)
  agentNote     String?
  viewingDate   String?
  viewingTime   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([status])
  @@index([assignedToId])
  @@index([contactMode])
  @@index([ownerUserId])
}

model SearchEvent {
  id           String   @id @default(cuid())
  query        String
  listingType  String?
  btsStation   String?
  district     String?
  propertyType String?
  filters      String   @default("{}")
  resultCount  Int      @default(0)
  source       String   @default("ai-search")
  createdAt    DateTime @default(now())

  @@index([createdAt])
  @@index([btsStation])
  @@index([propertyType])
  @@index([source])
}

model PropertyViewEvent {
  id           String   @id @default(cuid())
  propertySlug String
  propertyType String?
  listingType  String?
  district     String?
  btsStation   String?
  source       String   @default("direct")
  createdAt    DateTime @default(now())

  @@index([propertySlug])
  @@index([createdAt])
  @@index([district])
  @@index([propertyType])
}

model MatchingEvent {
  id            String   @id @default(cuid())
  eventType     String
  propertySlug  String?
  propertyTitle String?
  ownerUserId   String?
  posterRole    String?
  leadId        String?
  visitorName   String?
  visitorPhone  String?
  visitorEmail  String?
  metadata      String   @default("{}")
  createdAt     DateTime @default(now())

  @@index([eventType])
  @@index([createdAt])
  @@index([propertySlug])
  @@index([ownerUserId])
}

model UserSubscription {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  packageId       String
  extraSlots      Int
  pricePaid       Int
  startsAt        DateTime @default(now())
  expiresAt       DateTime
  status          String   @default("active")
  paymentStatus   String   @default("pending")
  paymentMethod   String?
  transactionRef  String?  @unique
  slipUrl         String?
  createdAt       DateTime @default(now())

  @@index([userId])
  @@index([status])
  @@index([paymentStatus])
}

model SavedProperty {
  id           String   @id @default(cuid())
  userId       String
  propertySlug String
  createdAt    DateTime @default(now())

  @@unique([userId, propertySlug])
  @@index([userId])
}

model SearchAlert {
  id          String    @id @default(cuid())
  userId      String
  name        String
  listingType String
  filters     String    @default("{}")
  frequency   String    @default("daily")
  active      Boolean   @default(true)
  lastSentAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([userId])
  @@index([active, frequency])
}

model PriceHistory {
  id          String       @id @default(cuid())
  propertyId  String
  property    UserProperty @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  price       Int
  listingType String
  changeType  String
  createdAt   DateTime     @default(now())

  @@index([propertyId])
  @@index([createdAt])
}

model AgentReview {
  id          String    @id @default(cuid())
  teamAgentId String
  teamAgent   TeamAgent @relation(fields: [teamAgentId], references: [id], onDelete: Cascade)
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  leadId      String?
  rating      Int
  comment     String    @default("")
  status      String    @default("pending")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([userId, teamAgentId])
  @@index([teamAgentId, status])
  @@index([status])
}
